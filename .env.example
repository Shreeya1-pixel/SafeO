# SafeO — environment variables (copy to backend/.env and fill in; never commit .env)
#
# Tier-3 LLM: local vLLM on AMD (no cloud API key). Start with amd_setup/start_vllm.sh
SECUREC_ENABLE_LLM_AUGMENTATION=true
SAFEO_LLM_SERVER_URL=http://localhost:8000/v1
SAFEO_LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# Band Agent IDs and API Keys (get these from band.ai → Agents → New Agent → External Agent)
BAND_MULTILINGUAL_AGENT_ID=
BAND_MULTILINGUAL_API_KEY=
BAND_POLICY_AGENT_ID=
BAND_POLICY_API_KEY=
BAND_FORENSICS_AGENT_ID=
BAND_FORENSICS_API_KEY=
BAND_REMEDIATION_AGENT_ID=
BAND_REMEDIATION_API_KEY=
BAND_ENABLED=true

# Set BAND_ENABLED=false to run without Band (graceful fallback, no keys required)
