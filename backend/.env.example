# SafeO FastAPI backend — copy to .env and fill in (never commit .env)
#
# Tier-3 LLM: local vLLM on AMD (no cloud API key). Start with SafeO/amd_setup/start_vllm.sh
SECUREC_ENABLE_LLM_AUGMENTATION=true
SAFEO_LLM_SERVER_URL=http://localhost:8000/v1
SAFEO_LLM_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# Optional AMD / GPU overrides
# SAFEO_AMD_DEVICE=cuda
# SAFEO_ENABLE_GPU_METRICS=true
# SAFEO_TIER2_MODEL_NAME=distilbert-base-uncased
# SAFEO_MULTILINGUAL_MODEL_NAME=aubmindlab/bert-base-arabertv2
